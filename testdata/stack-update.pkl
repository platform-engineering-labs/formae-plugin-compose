/*
 * Conformance Test: Update Resource (in-place)
 *
 * This file modifies mutable fields to trigger an in-place update.
 * Changes from resource.pkl:
 *   - composeFile: added "updated" label to web service
 *
 * These fields do NOT have createOnly=true, so formae should update
 * the resource in place without replacement.
 */
amends "@formae/forma.pkl"
import "@formae/formae.pkl"

import "@compose/compose.pkl"

local testRunID = read("env:FORMAE_TEST_RUN_ID")
local stackName = "plugin-sdk-test-stack"

forma {
  new formae.Stack {
    label = stackName
    description = "Plugin SDK conformance test stack"
  }

  new formae.Target {
    label = "docker-target"
    namespace = "DOCKER"
    config = new compose.Config {}
  }

  new compose.Stack {
    label = "test-stack"
    projectName = "formae-test-\(testRunID)"                    // unchanged (createOnly)
    composeFile = #"""
      services:
        web:
          image: nginx:alpine
          ports:
            - "18080:80"
          labels:
            updated: "true"
      """#                                                       // CHANGED - added label
  }
}
