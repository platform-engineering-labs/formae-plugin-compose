/// Docker Compose plugin schema.
/// Defines target configuration and resource types for Docker Compose stack management.
module compose

import "@formae/formae.pkl"

/// Target configuration for a Docker host.
/// Contains only the deployment location, NOT credentials.
/// The Docker socket or remote host to connect to.
open class Config {
  hidden fixed type: String = "Docker"
  hidden host: String = "unix:///var/run/docker.sock"

  fixed Type: String = type
  fixed Host: String = host
}

/// Resource type constant for Stack.
const type: String = "DOCKER::Compose::Stack"

/// A Docker Compose stack resource.
/// Manages a docker compose project lifecycle.
@formae.ResourceHint {
  type = module.type
  identifier = "$.projectName"
  discoverable = true
}
class Stack extends formae.Resource {
  fixed hidden type: String = module.type

  /// The compose project name, used as native ID.
  /// Cannot be changed after creation (triggers replacement).
  @formae.FieldHint { createOnly = true }
  projectName: String

  /// The compose YAML content (mutable, changes trigger update).
  /// Nullable because discovered stacks may not have the compose file content
  /// available (it can't be retrieved from Docker).
  @formae.FieldHint {}
  composeFile: String?

  /// Published endpoints discovered from running containers.
  /// Keys are "service:containerPort" (e.g., "lgtm:3000"), values are
  /// resolved URLs (e.g., "http://localhost:3000"). Computed automatically
  /// from Docker — do not set manually.
  @formae.FieldHint { hasProviderDefault = true }
  endpoints: Mapping<String, String>?

  /// Read-only, the project status.
  status: String?

  local parent = this
  hidden res: StackResolvable = new {
    label = parent.label
    stack = parent.stack?.label
  }
}

/// Resolvable reference to a Stack.
/// Allows other resources to reference Stack properties.
open class StackResolvable extends formae.Resolvable {
  hidden type = module.type
  local _self = this

  /// Published endpoints mapping. Use at() to access individual endpoints:
  ///   stack.res.endpoints.at("grafana:3000")  // "http://localhost:3000"
  hidden endpoints: formae.MappingResolvable = new formae.MappingResolvable {
    label = _self.label
    type = _self.type
    stack = _self.stack
    property = "endpoints"
  }

  hidden projectName: formae.Resolvable = new formae.Resolvable {
    label = _self.label
    type = _self.type
    stack = _self.stack
    property = "projectName"
  }
}
